{
  "name": "evogarden",
  "version": "2.33.1",
  "description": "A dynamic garden simulation where flowers evolve under the pressure of insects and birds. Watch a Darwinian battlefield unfold as flowers, insects, and birds interact in a delicate ecosystem, with visual traits driven by NEAT Algorithm.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "buildGH": "tsc && vite build --base=/EvoGarden/",
    "preview": "vite preview",
    "show": "npx playwright show-report",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test e2e/app.spec.ts --update-snapshots"
  },
  "author": "Cristian Gonzalez <cristian.glez.m@gmail.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@cristianglezm/flower-evolver-wasm": "^3.0.0",
    "@cristianglezm/live-commentary-widget": "^1.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "dexie": "^4.4.4",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0",
    "vite-plugin-pwa": "^1.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.9",
    "baseline-browser-mapping": "^2.10.38",
    "jsdom": "^29.0.1",
    "react-devtools": "^7.0.1",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.0.8"
  }
}
